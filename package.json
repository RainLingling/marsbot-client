{
  "name": "marsbot-client",
  "version": "1.0.2",
  "description": "Marsbot 本地离线客户端 - AI信贷风控分析工具",
  "main": "dist/main/main/index.js",
  "author": {
    "name": "RainLingling"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "pnpm build && electron-builder --publish never",
    "package:win": "pnpm build && electron-builder --win --publish never",
    "package:mac": "pnpm build && electron-builder --mac --publish never",
    "package:linux": "pnpm build && electron-builder --linux --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.marsbot.client",
    "productName": "Marsbot Client",
    "copyright": "Copyright © 2025 RainLingling",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Finance"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Marsbot Client"
    }
  },
  "packageManager": "pnpm@10.33.3",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "streamdown": "^2.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.9.0",
    "xlsx": "^0.18.5"
  }
}
